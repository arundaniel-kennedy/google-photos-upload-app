# Google OAuth 2.0 credentials (from Google Cloud Console > Credentials).
# Enable the "Photos Library API" and add the redirect URI below as an authorized redirect.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must exactly match an Authorized redirect URI in the Google Cloud console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Only this Google account may access the admin dashboard and approve photos.
ADMIN_EMAIL=your_name@gmail.com

# Max upload size in bytes (default 2.5 GB).
MAX_UPLOAD_BYTES=2621440000

# Set to "true" in production (served over HTTPS) so session cookies get the Secure flag.
COOKIE_SECURE=false

# Only needed behind a reverse proxy/custom domain if uploads are blocked with a
# 403 "origin check" error. Comma-separated hostnames the browser sees, e.g.:
# TRUSTED_ORIGINS=photos.example.com,192.168.1.50:3001
TRUSTED_ORIGINS=
